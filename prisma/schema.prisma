generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("cashier") // admin, cashier, manager
  name      String
  createdAt DateTime @default(now())
  invoices  Invoice[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id           Int           @id @default(autoincrement())
  name         String
  barcode      String?       @unique
  categoryId   Int
  category     Category      @relation(fields: [categoryId], references: [id])

  // Pricing: supports both weight-based and unit-based
  priceType    String        @default("unit") // "unit" or "weight"
  price        Float         // price per unit or per kg
  costPrice    Float         // supplier price

  // Stock
  stock        Float         @default(0)
  minStock     Float         @default(5)

  // For weight-based: track in kg, for unit: track in pieces
  unit         String        @default("piece") // "piece", "kg", "gram", "pack"

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  invoiceItems InvoiceItem[]
  stockLogs    StockLog[]
}

model Invoice {
  id          Int           @id @default(autoincrement())
  invoiceNo   String        @unique
  userId      Int
  user        User          @relation(fields: [userId], references: [id])
  total       Float
  discount    Float         @default(0)
  finalTotal  Float
  paymentType String        @default("cash") // cash, card, mix
  createdAt   DateTime      @default(now())
  items       InvoiceItem[]
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  price     Float   // price at time of sale
  total     Float
}

model StockLog {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  type        String   // "in" (supply) or "out" (sale/loss)
  quantity    Float
  reason      String   // "purchase", "sale", "return", "damage"
  notes       String?
  createdAt   DateTime @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}