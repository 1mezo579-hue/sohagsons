// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                Int                 @id @default(autoincrement())
  username          String              @unique
  password          String
  role              String              @default("cashier") // admin, manager, cashier, technician
  name              String
  createdAt         DateTime            @default(now())
  invoices          Invoice[]
  expenses          Expense[]
  maintenanceOrders MaintenanceOrder[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id                Int                 @id @default(autoincrement())
  name              String
  barcode           String?             @unique
  categoryId        Int?
  category          Category?           @relation(fields: [categoryId], references: [id])
  priceType         String              @default("unit") // unit, weight, service
  price             Float
  costPrice         Float               @default(0)
  stock             Float               @default(0)
  minStock          Float               @default(5)
  unit              String              @default("piece")
  expiryDate        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  invoiceItems      InvoiceItem[]
  stockLogs         StockLog[]
  traderInvoiceItems TraderInvoiceItem[]

  @@index([name])
  @@index([barcode])
}

model Invoice {
  id          Int           @id @default(autoincrement())
  invoiceNo   String        @unique
  userId      Int
  user        User          @relation(fields: [userId], references: [id])
  customerId  Int?
  customer    Customer?     @relation(fields: [customerId], references: [id])
  total       Float
  discount    Float         @default(0)
  finalTotal  Float
  paymentType String        @default("cash") // cash, card, credit
  orderType   String        @default("shop") // shop, delivery
  deliveryFee Float         @default(0)
  createdAt   DateTime      @default(now())
  items       InvoiceItem[]
}

model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Float
  price     Float
  total     Float
}

model StockLog {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String   // in, out, adjust
  quantity  Float
  reason    String
  notes     String?
  createdAt DateTime @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Customer {
  id         Int                 @id @default(autoincrement())
  name       String
  phone      String              @unique
  address    String?
  points     Float               @default(0)
  totalSpent Float               @default(0)
  balance    Float               @default(0) // credit balance
  notes      String?
  createdAt  DateTime            @default(now())
  invoices   Invoice[]
  maintenance MaintenanceOrder[]
}

model Expense {
  id          Int      @id @default(autoincrement())
  amount      Float
  category    String   // rent, electricity, salaries, tools, marketing, other
  description String?
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}

model Trader {
  id        Int             @id @default(autoincrement())
  name      String
  phone     String?
  company   String?
  address   String?
  balance   Float           @default(0) // positive = we owe them, negative = they owe us
  notes     String?
  createdAt DateTime        @default(now())
  invoices  TraderInvoice[]
}

model TraderInvoice {
  id        Int                 @id @default(autoincrement())
  invoiceNo String              @unique
  traderId  Int
  trader    Trader              @relation(fields: [traderId], references: [id])
  total     Float
  paid      Float               @default(0)
  remaining Float
  status    String              @default("pending") // pending, partial, paid
  notes     String?
  createdAt DateTime            @default(now())
  items     TraderInvoiceItem[]
}

model TraderInvoiceItem {
  id              Int           @id @default(autoincrement())
  traderInvoiceId Int
  traderInvoice   TraderInvoice @relation(fields: [traderInvoiceId], references: [id], onDelete: Cascade)
  productId       Int?
  product         Product?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  description     String
  quantity        Float
  price           Float
  total           Float
}

model MaintenanceOrder {
  id            Int      @id @default(autoincrement())
  orderNo       String   @unique // e.g. "MT-1001"
  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id])
  customerName  String
  customerPhone String
  deviceType    String   // mobile, laptop, computer, other
  deviceBrand   String
  deviceModel   String
  serialNo      String?  // IMEI or Laptop serial number
  problem       String
  techNotes     String?
  cost          Float
  paid          Float    @default(0)
  remaining     Float
  status        String   @default("pending") // pending, checking, repairing, completed, delivered, cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
}
